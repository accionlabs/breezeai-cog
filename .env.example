# breezeai-cog environment variables.
#
# Copy to `.env` (auto-loaded) and uncomment what you need. Every value shown is the
# default. CLI flags override env vars. Most vars use the BREEZEAI_COG_ prefix; AWS and
# a few backend vars also accept their conventional unprefixed names (noted inline).

# ── Analysis ──────────────────────────────────────────────────────────────────
# Comma-separated language allow-list; empty = auto-detect all. (alias: BREEZEAI_COG_LANGUAGES)
#BREEZEAI_COG_LANGUAGE=
# Emit in-body statements (route / API / DB detection): 1|true|yes
#BREEZEAI_COG_CAPTURE_STATEMENTS=false
# Worker processes; empty = CPU count
#BREEZEAI_COG_JOBS=
# Max captured statement `text` length (characters)
#BREEZEAI_COG_TEXT_TRUNCATION_LIMIT=1000
# Skip files larger than this (bytes)
#BREEZEAI_COG_MAX_FILE_SIZE=2000000
# Per-file tree-sitter parse timeout (seconds; 0 disables)
#BREEZEAI_COG_PARSE_TIMEOUT=10.0

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
#BREEZEAI_COG_LOG_LEVEL=INFO
# plaintext | json
#BREEZEAI_COG_LOG_FORMAT=plaintext
#BREEZEAI_COG_LOG_TO_FILE=true
#BREEZEAI_COG_LOG_LOCATION=./logs

# ── Server ────────────────────────────────────────────────────────────────────
#BREEZEAI_COG_PORT=3000

# ── Backend upload / notification ─────────────────────────────────────────────
# Upload analysis to the backend: 1|true|yes. Requires baseurl + uuid + user_api_key.
#BREEZEAI_COG_UPLOAD=false
# Breeze backend base URL. (alias: BREEZE_API_URL)
#BREEZEAI_COG_BASEURL=
#BREEZEAI_COG_UUID=
# Backend API key — sent as the `api-key` header. (alias: API_KEY)  [SECRET]
#BREEZEAI_COG_USER_API_KEY=

# ── AWS / S3 (streaming endpoints: analyze-diff / analyze-sql / analyze-es) ────
# Conventional unprefixed names. (AWS_ACCESS_KEY alias: AWS_ACCESS_KEYID)
# Credentials default to boto3's provider chain — IAM Roles for Service Accounts
# (IRSA) in-cluster, or your local AWS profile for dev. Static keys are optional:
# uncomment BOTH below (e.g. for local dev without a profile) and they take
# precedence over the provider chain.
#AWS_ACCESS_KEY=
#AWS_SECRET_KEY=                 # [SECRET]
#AWS_REGION=us-west-2
#AWS_S3_BUCKET=
