# Keep the Docker build context small and reproducible.
.git
.github
.venv
venv
.direnv
.envrc

# Local env / secrets (never bake into an image)
.env
.env.*
!.env.example

# Caches and build artifacts
__pycache__/
*.py[cod]
.pytest_cache
.mypy_cache
.ruff_cache
*.egg-info
build/
dist/

# Local runtime output
logs/
out/

# Editor / tooling
.claude
.idea
.vscode
